{
  "name": "product-catalog-backend",
  "version": "1.0.0",
  "description": "High-performance Product Catalog Backend",
  "main": "src/index.js",
  "scripts": {
    "start": "node src/index.js",
    "dev": "nodemon src/index.js",
    "proxy": "node proxy/proxy-server.js",
    "seed": "node scripts/seedProducts.js",
    "generate": "node scripts/generateProducts.js",
